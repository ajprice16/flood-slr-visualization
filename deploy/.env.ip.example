# IP-only deployment mode (no TLS certificate)
# Replace with your Jetstream2 public IP
PUBLIC_IP=149.165.154.58

# Bind gateway directly on port 80
GATEWAY_PORT_BIND=80:80

# Backend request validation and browser CORS policy for IP access
TRUSTED_HOSTS=localhost,127.0.0.1,gateway,149.165.154.58
CORS_ALLOW_ORIGINS=http://149.165.154.58

# Performance tuning defaults for a 16-core / 60 GB host
UVICORN_WORKERS=12
UVICORN_KEEPALIVE=15
TILE_CACHE_SIZE=2048
GDAL_CACHEMAX=2048
GDAL_NUM_THREADS=ALL_CPUS
OMP_NUM_THREADS=16
