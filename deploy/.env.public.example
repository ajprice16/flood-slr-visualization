# Public hostname (must point A/AAAA DNS record at your Jetstream2 IP)
SITE_HOSTNAME=slr.example.org

# Keep internal gateway bound to localhost while Caddy serves public 80/443
GATEWAY_PORT_BIND=127.0.0.1:8080:80

# Backend request validation and browser CORS policy
TRUSTED_HOSTS=localhost,127.0.0.1,gateway,caddy,slr.example.org
CORS_ALLOW_ORIGINS=https://slr.example.org

# Optional backend tile cache tuning for larger instances
# TILE_CACHE_SIZE=1024
